{
	"name": "n8n-nodes-prompt-dataset-generator",
	"version": "1.0.0",
	"description": "n8n Community Node for generating prompt datasets from workflows using AI Gateway",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"prompt",
		"dataset",
		"evaluation",
		"ai-gateway"
	],
	"license": "MIT",
	"homepage": "https://github.com/rigzindorje/PromptDatasetGenerator-n8n",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rigzindorje/PromptDatasetGenerator-n8n.git"
	},
	"engines": {
		"node": ">=18.10",
		"pnpm": ">=7.18"
	},
	"packageManager": "pnpm@8.6.2",
	"main": "index.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint \"nodes/**/*.ts\" \"credentials/**/*.ts\"",
		"lintfix": "eslint \"nodes/**/*.ts\" \"credentials/**/*.ts\" --fix",
		"prepublishOnly": "pnpm build && pnpm lint -o .eslintcache && pnpm test",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/AIGatewayApi.credentials.js",
			"dist/credentials/N8nDataTables.credentials.js"
		],
		"nodes": [
			"dist/nodes/PromptDatasetGenerator/PromptDatasetGenerator.node.js"
		]
	},
	"devDependencies": {
		"@types/jest": "^29.5.5",
		"@types/node": "^18.16.16",
		"@typescript-eslint/eslint-plugin": "^6.21.0",
		"@typescript-eslint/parser": "^6.21.0",
		"eslint": "^8.42.0",
		"eslint-plugin-n8n-nodes-base": "^1.11.0",
		"gulp": "^4.0.2",
		"jest": "^29.6.2",
		"n8n-workflow": "^1.0.0",
		"prettier": "^2.7.1",
		"ts-jest": "^29.1.1",
		"typescript": "^5.1.6"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "node",
		"testMatch": [
			"**/*.test.ts"
		]
	}
}
